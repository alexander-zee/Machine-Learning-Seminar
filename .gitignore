# Data policy:
# - keep folder scaffold + README placeholders in Git for new users
# - keep large/generated data files out of Git
paper_data/
*.csv
*.parquet
*.feather
*.pkl
*.pickle

# Ignore everything under data by default...
data/**
# ...but keep folder scaffold and instructions
!data/
!data/.gitkeep
!data/raw/
!data/raw/.gitkeep
!data/raw/README.md
